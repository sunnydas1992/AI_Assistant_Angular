# ============================================================================
# QA Assistant – Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env itself.
# ============================================================================

# --- Security ---
# Session signing key. MUST be changed from the default in production.
SESSION_SECRET_KEY=change-me-to-a-random-64-char-string

# --- Logging ---
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# --- Session management ---
QA_SESSION_TTL=14400            # Session time-to-live in seconds (default 4h)
QA_SESSION_MAX_COUNT=150        # Max concurrent sessions before eviction
QA_SESSION_EVICTION_INTERVAL=300  # Eviction check interval in seconds

# --- Rate limiting ---
QA_RATE_LIMIT_REQUESTS=60       # Max requests per window per session
QA_RATE_LIMIT_WINDOW=60         # Window size in seconds

# --- Thread pool / concurrency ---
QA_THREAD_POOL_SIZE=64          # Thread pool workers for blocking I/O
QA_HEAVY_CONCURRENCY=30         # Semaphore limit for heavy operations

# --- AWS Bedrock ---
QA_BEDROCK_MODELS_CACHE_TTL=300   # Cache TTL for model list (seconds)
QA_BEDROCK_READ_TIMEOUT=120       # Read timeout for Bedrock calls (seconds)
QA_BEDROCK_CONNECT_TIMEOUT=10     # Connect timeout for Bedrock calls (seconds)

# --- Embedding model ---
QA_EMBEDDING_MODEL=all-MiniLM-L6-v2  # SentenceTransformer model name

# --- Xray integration (optional) ---
XRAY_TEST_ISSUE_TYPE_NAME=Test   # Jira issue type name for Xray Tests
XRAY_TEST_ISSUE_TYPE_ID=         # Jira issue type ID (leave empty to auto-detect)
XRAY_CLOUD_CLIENT_ID=            # Xray Cloud API client ID
XRAY_CLOUD_CLIENT_SECRET=        # Xray Cloud API client secret
XRAY_CLOUD_BASE_URL=https://xray.cloud.getxray.app
XRAY_STEP_PUSH_MODE=auto         # auto | always | never
